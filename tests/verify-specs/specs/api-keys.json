{
  "module": "api-keys",
  "_about": "api-keys 모듈의 api/shell 케이스 결정적 검증 스펙. 기대값은 admin-guide/api-keys.md(가이드)에서 도출하고 경로는 /openapi.json로 확정. 약 20% 표본 + 확정 버그 M-2(형제 프로젝트 경계) 포함. 부수효과: 키 생성/감사 행만(스캔은 403 거부라 미기동).",
  "vars": [
    { "name": "BACKEND_TEAM", "as": "team_admin_backend", "method": "GET", "path": "/v1/projects", "list": true, "where": { "name": "portal-api" }, "field": "team_id" },
    { "name": "PORTAL_API_PID", "as": "team_admin_backend", "method": "GET", "path": "/v1/projects", "list": true, "where": { "name": "portal-api" }, "field": "id" },
    { "name": "SCANPIPE_PID", "as": "team_admin_backend", "method": "GET", "path": "/v1/projects", "list": true, "where": { "name": "scan-pipeline" }, "field": "id" }
  ],
  "checks": [
    {
      "tc": "TC-APIKEY-02-001", "channel": "api", "as": "team_admin_backend",
      "_expect": "팀 범위 키 발급 시 201, raw_key가 tos_<8hex>_<32> 형식",
      "request": { "method": "POST", "path": "/v1/api-keys", "body": { "name": "verify-team-key", "scope": "team", "team_id": "${BACKEND_TEAM}" } },
      "expect": { "status": 201, "bodyMatches": "tos_[0-9a-f]{8}_[A-Za-z0-9_-]{32}" }
    },
    {
      "tc": "TC-APIKEY-03-002", "channel": "api", "as": "team_admin_backend",
      "_expect": "team_admin은 org 범위 발급 권한이 없어 403",
      "request": { "method": "POST", "path": "/v1/api-keys", "body": { "name": "verify-org-deny", "scope": "org" } },
      "expect": { "status": 403 }
    },
    {
      "tc": "TC-APIKEY-03-004", "channel": "api", "as": "developer",
      "_expect": "developer는 team 범위 발급 권한이 없어 403",
      "request": { "method": "POST", "path": "/v1/api-keys", "body": { "name": "verify-dev-team-deny", "scope": "team", "team_id": "${BACKEND_TEAM}" } },
      "expect": { "status": 403 }
    },
    {
      "tc": "TC-APIKEY-04-002", "channel": "api", "as": "team_admin_backend",
      "_expect": "expires_in_days=0은 하한(1) 위반이라 422",
      "request": { "method": "POST", "path": "/v1/api-keys", "body": { "name": "verify-ttl-0", "scope": "team", "team_id": "${BACKEND_TEAM}", "expires_in_days": 0 } },
      "expect": { "status": 422 }
    },
    {
      "tc": "TC-APIKEY-04-003", "channel": "api", "as": "team_admin_backend",
      "_expect": "expires_in_days=1826은 상한(1825) 초과라 422",
      "request": { "method": "POST", "path": "/v1/api-keys", "body": { "name": "verify-ttl-1826", "scope": "team", "team_id": "${BACKEND_TEAM}", "expires_in_days": 1826 } },
      "expect": { "status": 422 }
    },
    {
      "tc": "TC-APIKEY-04-006-setup", "channel": "api", "as": "team_admin_backend",
      "_expect": "portal-api 전용 project 범위 키 발급(다음 체크에서 사용). 201 + raw_key 캡처",
      "request": { "method": "POST", "path": "/v1/api-keys", "body": { "name": "verify-proj-scope-key", "scope": "project", "project_id": "${PORTAL_API_PID}" } },
      "capture": { "PROJ_KEY": "raw_key" },
      "expect": { "status": 201 }
    },
    {
      "tc": "TC-APIKEY-04-006", "channel": "api", "useKey": "${PROJ_KEY}", "knownBug": "M-2",
      "_expect": "portal-api 전용 키로 형제 프로젝트(scan-pipeline) 스캔 트리거는 프로젝트 경계 위반이라 403 (원 실행 시 202/409 누수 = 버그). 403이라 스캔 미기동.",
      "request": { "method": "POST", "path": "/v1/projects/${SCANPIPE_PID}/scans", "body": { "kind": "source" } },
      "expect": { "status": 403 }
    },
    {
      "tc": "TC-APIKEY-09-003", "channel": "api", "useKey": "tos_deadbeef_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
      "_expect": "존재하지 않는 prefix 키는 인증 실패 401",
      "request": { "method": "POST", "path": "/v1/projects/${PORTAL_API_PID}/scans", "body": { "kind": "source" } },
      "expect": { "status": 401 }
    },
    {
      "tc": "TC-APIKEY-09-005", "channel": "api",
      "_expect": "인증 헤더 없으면 401",
      "request": { "method": "POST", "path": "/v1/projects/${PORTAL_API_PID}/scans", "body": { "kind": "source" } },
      "expect": { "status": 401 }
    },
    {
      "tc": "TC-APIKEY-08-001", "channel": "shell",
      "_expect": "키 발급이 audit_logs에 api_keys create 행을 남김(앞 체크들이 키를 생성했으므로 ≥1)",
      "sql": "SELECT count(*) FROM audit_logs WHERE target_table='api_keys' AND action='create';",
      "expect": { "rowMatches": "^[1-9][0-9]*$" }
    }
  ]
}
