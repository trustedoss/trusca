        "jsonEquals": {
          "upgrade_recommendation.recommended_version": null
        }
      }
    },
    {
      "tc": "TC-VULN-07-006",
      "channel": "api",
      "as": "team_admin_backend",
      "_expect": "가이드: 타 팀 호출자는 404(existence-hidden, 403 아님). 비회원 team_admin_backend가 portal-web finding 전이 호출.",
      "request": {
        "method": "PATCH",
        "path": "/v1/vulnerability_findings/${F_NEW}/status",
        "body": {
          "status": "analyzing",
          "justification": "outsider probe - must be 404"
