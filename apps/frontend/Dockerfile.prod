# TrustedOSS Portal — frontend (production image).
#
# Multi-stage build:
#   1. `build`   — node:20.18.1-alpine, runs `npm ci && npm run build` to
#                  produce the static Vite bundle in /app/dist.
#   2. `runtime` — nginx:1.27.3-alpine, serves /app/dist on :8080 with
#                  SPA fallback (any unknown path → index.html).
#
# Why a separate Dockerfile and not a target in the dev one? The dev image
# bind-mounts source for HMR; mixing that with a production multi-stage
# build complicated the layer cache and made `docker-compose -f
# docker-compose.dev.yml build` accidentally pull the heavy build stage.
# Phase 7 PR #20 (this file) introduces the prod artifact cleanly.
#
# CLAUDE.md core rule #9: pin tags, no `:latest`. Both stages pin minor +
# patch. `node:20.18.1-alpine` matches the dev Dockerfile to keep parity
# between the dev HMR build and the prod tsc emit.

# ---------- 1. build ----------
FROM node:20.18.1-alpine AS build

WORKDIR /app

# Install deps first to maximize layer cache hits when only source changes.
COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

# Source comes after deps so a source-only edit doesn't bust the npm cache.
COPY . .

# VITE_API_BASE_URL is baked into the static bundle at build time.
# Marathon bundle 7 — API path consistency: the SPA emits /v1/...
# fetches relative to the bundle origin (same-origin). Traefik
# (docker-compose.yml) routes /v1/*, /auth/*, /ws/* to the backend
# directly — no /api prefix strip. Override per-deployment with the
# build arg only if your edge proxy needs a different base.
ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN npm run build

# ---------- 2. runtime ----------
FROM nginx:1.27.3-alpine AS runtime

# tini gives us clean SIGTERM handling — without it nginx ignores the
# Docker stop signal for 10s and the orchestrator force-kills.
RUN apk add --no-cache tini curl

# Drop the stock nginx default site; ship our SPA-aware config instead.
RUN rm -f /etc/nginx/conf.d/default.conf
COPY nginx/nginx.conf /etc/nginx/nginx.conf
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

# Static assets from the build stage.
COPY --from=build /app/dist /usr/share/nginx/html

# Run as the unprivileged `nginx` user that the base image already
# provisions. We listen on :8080 (>1024) so the non-root user can bind.
EXPOSE 8080

# Healthcheck endpoint — nginx serves /healthz with a literal 200 body.
HEALTHCHECK --interval=10s --timeout=5s --retries=6 --start-period=20s \
    CMD curl -fsS http://127.0.0.1:8080/healthz || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["nginx", "-g", "daemon off;"]
