# syntax=docker/dockerfile:1.7
#
# TrustedOSS Portal — Celery worker image.
#
# This image carries the heavy SCA toolchain (cdxgen / scancode / Trivy + JRE
# + Node + per-ecosystem lockfile resolvers) that backend API containers do
# NOT need. Splitting it out keeps the API image small (~200MB) while the
# worker is deployed and rolled independently. Per CLAUDE.md core rule #3
# (ORT/cdxgen/scancode/Trivy must run inside Celery — never synchronously)
# this is the only image that ships the tools.
#
# PR-A2: ORT (~600MB extracted) was removed. The broken `ort evaluate` stage
# is replaced by scancode-toolkit, which runs first-party license DETECTION
# over the cloned source tree (third-party dependency licenses stay declared,
# from cdxgen). scancode is pure Python, installed into an isolated virtualenv
# (so its large dep tree never collides with the backend's pinned deps) and
# symlinked onto $PATH. It ships manylinux + aarch64 wheels for its native
# deps, so the image builds on both amd64 CI and arm64 (Apple Silicon / Colima)
# without an apt-amd64-only package (the .NET-on-arm64 regression lesson).
#
# Layer strategy: each tool is installed in its own RUN so buildx/GHA cache
# can re-use unchanged layers. The JVM (Temurin 21) is still installed because
# cdxgen shells into Maven / Gradle for Java SBOM enumeration.
#
# All shipped tools are Apache-2.0 unless noted:
#   cdxgen     — https://github.com/CycloneDX/cdxgen         (Apache-2.0)
#   scancode   — https://github.com/aboutcode-org/scancode-toolkit (Apache-2.0)
#   Trivy      — https://github.com/aquasecurity/trivy       (Apache-2.0)
#   Temurin    — Eclipse Temurin JRE 21                      (GPL-2.0-CE — runtime
#                only; Classpath Exception lets user code stay non-GPL).
#   Maven      — Apache Maven 3.9.x                          (Apache-2.0)
#   Gradle     — Gradle 8.14.x                               (Apache-2.0)
#   Composer   — getcomposer.org                             (MIT)
#   Ruby/MRI   — ruby-lang.org                               (Ruby License / BSD)
#   Bundler    — bundler.io                                  (MIT)
#   Cargo/Rust — rust-lang.org                               (MIT/Apache-2.0)
#   Go         — go.dev                                      (BSD-3-Clause)
#   .NET SDK 8 — Microsoft                                   (MIT — runtime;
#                see github.com/dotnet/runtime/blob/main/LICENSE.TXT)

# ---------------------------------------------------------------------------
# Stage 1: base — Python runtime + Python deps. Mirrors apps/backend/Dockerfile
# so the API and worker share the cached Python install layer when both are
# built on the same host.
# ---------------------------------------------------------------------------
# Chore P (Phase 8 worker-image refresh): bumped python:3.12.7 → 3.12.13.
# 6 patch releases of CPython security fixes land on top of the same Debian
# bookworm-slim base; all backend deps (asyncpg / sqlalchemy / fastapi)
# already support 3.12.x without changes. Stays on 3.12 (not 3.13) so the
# api Dockerfile (still on 3.12) and the worker share a Python ABI.
#
# Explicit `-bookworm` suffix: as of late 2026 the upstream `python:3.12-slim`
# tag was rebased onto Debian 13 (trixie). Our apt-repo additions (Microsoft
# `/debian/12/` + Adoptium `bookworm main`) and their signing keys are still
# pinned to bookworm. Trixie's `sqv` rejects the Microsoft repo's SHA1-bound
# binding signature ("Policy rejected non-revocation signature requiring
# second pre-image resistance ... SHA1 is not considered secure since
# 2026-02-01"). Stay on bookworm until both upstreams publish trixie-
# compatible signing keys; revisit when bumping to Python 3.13.
FROM python:3.12.13-slim-bookworm AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# psycopg2 (sync, used by alembic) needs libpq + a C compiler;
# curl powers the docker-compose healthcheck and tool downloads.
#
# `apt-get upgrade -y` (deterministic security patching of the base layer):
#   python:3.12.7-slim is debian-bookworm and pins each OS package to the
#   snapshot taken when the python image was built — so libgnutls30 lands
#   at 3.7.9-2+deb12u3 even after Debian publishes -u5 / -u6 to the
#   bookworm-security channel (CVE-2025-32988 / CVE-2025-32990, et al.).
#   Trivy flags those as HIGH+CRITICAL on the worker image. Running an
#   `upgrade` here pulls every installed OS package up to the latest
#   patch from the security channel, independently of when the upstream
#   python image is rebuilt. Repeated for the worker stage's apt run too,
#   because that one installs unzip/git/mercurial which can carry their
#   own transitive OS deps.
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        curl \
        ca-certificates \
        gnupg \
    && rm -rf /var/lib/apt/lists/*

# Marathon bundle 3 (D2) — install postgresql-client-17 so the
# ``trustedoss.backup.run`` Celery task can pg_dump / psql against
# Postgres directly via DATABASE_URL, without shelling back into the
# docker-compose stack (which would require docker-compose to be
# installed inside this worker image — a recursive dependency we do not
# want). The client major version matches the server Postgres 17 used
# by docker-compose.dev/prod.yml. Using the official PostgreSQL apt repo
# (Debian bookworm only ships postgresql-client-15 by default).
#
# Supply chain (M4): pin the PostgreSQL Global Development Group key
# fingerprint so a compromised upstream key URL cannot silently
# substitute a backdoored binary. The expected fingerprint is published
# at https://wiki.postgresql.org/wiki/Apt and re-checked at every
# build. A key rotation requires a deliberate Dockerfile edit + review.
RUN curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc -o /tmp/pgdg.asc \
    && gpg --show-keys --with-fingerprint --with-colons /tmp/pgdg.asc \
        | grep '^fpr:' \
        | grep -q ':B97B0AFCAA1A47F044F244A07FCC7D46ACCC4CF8:' \
    && gpg --dearmor -o /usr/share/keyrings/postgresql.gpg /tmp/pgdg.asc \
    && rm /tmp/pgdg.asc \
    && echo "deb [signed-by=/usr/share/keyrings/postgresql.gpg] https://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" \
        > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends postgresql-client-17 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt requirements-dev.txt /app/
# Install both files explicitly. requirements-dev.txt starts with
# `-r requirements.txt`, so a single `pip install -r requirements-dev.txt`
# is functionally equivalent — but listing both makes the dependency
# surface visible to a build-cache miss diagnostic and forecloses a
# pip behaviour change that would silently drop the transitive include.
RUN pip install --upgrade pip \
    && pip install -r requirements.txt -r requirements-dev.txt

# ---------------------------------------------------------------------------
# Stage 2: worker — base + JRE 21 + Node 20 LTS + cdxgen + scancode + Trivy.
# ---------------------------------------------------------------------------
FROM base AS worker

# OS deps for the SCA toolchain. unzip → Gradle zip extraction; git/mercurial
# → VCS fetch + cdxgen VCS analyzers; ca-certificates already installed in
# stage 1.
#
# scancode native deps (PR-A2):
#   libgomp1 + libpopt0 — runtime libs for scancode's bundled license matchers.
#   libicu-dev + pkg-config — BUILD deps for PyICU, a scancode transitive dep
#     that ships NO aarch64 wheel and must compile from sdist on arm64 (Apple
#     Silicon / Colima). PyICU's setup.py probes ICU via pkg-config and links
#     against the ICU dev headers; without these the arm64 image build fails
#     with "Failed to build 'pyicu'". (build-essential is already present from
#     stage 1.) This is the scancode equivalent of the .NET-on-arm64 lesson:
#     pick an install path that resolves on BOTH architectures.
# Java is installed below from Eclipse Temurin (apt repo) — cdxgen's
# Maven/Gradle SBOM enumeration needs JRE 21, and Debian bookworm only ships
# JDK 17 by default.
# `apt-get upgrade -y` repeated here so anything pulled by unzip/git/mercurial
# also lands on the bookworm-security patch level (see stage 1 comment).
RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
        unzip \
        git \
        mercurial \
        libgomp1 \
        libpopt0 \
        libicu-dev \
        pkg-config \
        libarchive13 \
        libmagic1 \
    && rm -rf /var/lib/apt/lists/*

# ---- Eclipse Temurin JRE 21 (GPL-2.0-CE — runtime only, Classpath
#      Exception lets user code stay non-GPL). cdxgen shells into Maven /
#      Gradle for Java SBOM enumeration and those need Java 21.
#      Adoptium publishes per-arch debs via their apt repo.
RUN curl -fsSL https://packages.adoptium.net/artifactory/api/gpg/key/public \
        | gpg --dearmor -o /usr/share/keyrings/adoptium.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/adoptium.gpg] https://packages.adoptium.net/artifactory/deb bookworm main" \
        > /etc/apt/sources.list.d/adoptium.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends temurin-21-jre \
    && rm -rf /var/lib/apt/lists/* \
    && java -version

# JAVA_HOME is arch-suffixed by Temurin (`/usr/lib/jvm/temurin-21-jre-{amd64,arm64}`).
# Resolve at build time so the same Dockerfile works on x86_64 and arm64 hosts.
RUN ln -sfn "/usr/lib/jvm/temurin-21-jre-$(dpkg --print-architecture)" /usr/lib/jvm/java-21
ENV JAVA_HOME=/usr/lib/jvm/java-21 \
    PATH=/usr/lib/jvm/java-21/bin:$PATH

# ---- Node.js 20.18.1 (Active LTS "Iron") via NodeSource. -------------------
# We pin the deb major (20.x) via the NodeSource distribution and the patch
# via apt-mark hold — NodeSource repos only carry the latest in the 20.x
# line, but pinning here documents intent and lets us bump deliberately.
#
# npm self-upgrade to 11.13.0 (deterministic security patching of the npm
# CLI bundled with Node 20.x): NodeSource Node.js 20.18.x ships with npm
# 10.8.2, whose bundled deps (cross-spawn 7.0.3, glob 10.4.2, minimatch
# 9.0.5, tar 6.2.1) carry 11 HIGH Trivy findings under
# usr/lib/node_modules/npm/node_modules/* (CVE-2024-21538 cross-spawn ReDoS
# + CVE-2025-64756 glob CmdInjection + 3 minimatch DoS + 6 tar
# arbitrary-write/path-traversal). npm 11.13.0 drops cross-spawn entirely
# and pulls bundled tar 7.5.13 / glob 13.0.6 / minimatch 10.2.5, all above
# the highest fixed-version Trivy reports. The npm CLI is only invoked at
# image-build time (this stage's `npm install -g cdxgen`) — the Celery
# worker runtime never shells to npm — but Trivy scans the whole image
# filesystem and the npm bundle is on it, so the only way to keep the
# image-scan gate green without `.trivyignore` entries for tooling-not-
# reached-at-runtime is to ship a patched npm.
# Chore P (Phase 8 worker-image refresh): bumped 11.13.0 → 11.14.1
# (latest 11.x as of 2026-05). Same drop-cross-spawn / bundled-tar 7.x
# rationale as the original 11.13.0 bump; 11.14.1 picks up further
# bundled-dep patches (npm changelog 2026-04~05).
ENV NODE_MAJOR=20 \
    NPM_VERSION=11.14.1
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g "npm@${NPM_VERSION}" \
    && node --version \
    && npm --version

# ---- cdxgen 12.3.3 (Apache-2.0). -------------------------------------------
# CycloneDX SBOM generator, 30+ ecosystems. The 12.x line trims the 11.x
# transitive deps tree (drops cacache / pacote / @npmcli/run-script and
# the cross-spawn 7.0.3 chain underneath) — that's the ~23 HIGH npm CVEs
# Trivy flagged on cdxgen 11.11.0 (CVE-2024-21538 cross-spawn ReDoS et al.).
# 12.x still supports Node 20 LTS via `engines.node: ^20 || ^22 || ^24 || ^25`.
# We install globally so it lands on PATH for the celery worker.
#
# Install flags:
#   --omit=dev      drops devDependencies (biome / poku / sinon / typescript)
#                   so the image stays lean. Effective.
#   --omit=optional kept for documentation-of-intent value, but does NOT
#                   actually drop `@cdxgen/cdxgen-plugins-bin` from the
#                   image. cdxgen 12.x ships a postinstall script that
#                   downloads the plugin bundle independently of the
#                   optionalDependencies key — verified empirically when
#                   commit a1e2e14's Trivy run still found all 12 HIGH +
#                   1 CRITICAL gobinary findings inside
#                   .../node_modules/@cdxgen/cdxgen-plugins-bin*/plugins/
#                   despite the flag.
#                   Those 12 CVEs are runtime-UNREACHED — our cdxgen
#                   invocation in apps/backend/integrations/cdxgen.py
#                   only passes `-r -o <path> --spec-version 1.5 <src>`
#                   and never executes any plugin (OSV matching is owned
#                   by Dependency-Track, image SAST is out of scope).
#                   The CVEs are therefore listed in `.trivyignore` at
#                   the workspace root, category (3) per its policy
#                   header, with per-CVE reach analysis. Phase 8
#                   hardening backlog: carve the plugins-bin directory
#                   out at image build time once we verify it doesn't
#                   break cdxgen's startup self-test.
#                   IMPORTANT: --omit=dev (devDependencies) and
#                   --omit=optional (optionalDependencies) are independent
#                   npm-config keys. If a future change needs cdxgen's
#                   bundled scanners (e.g. wiring osv-scanner into the
#                   pipeline), drop --omit=optional and add corresponding
#                   .trivyignore entries with reach analysis — do not
#                   rollback the gate.
ENV CDXGEN_VERSION=12.3.3
RUN npm install -g --omit=dev --omit=optional "@cyclonedx/cdxgen@${CDXGEN_VERSION}" \
    && cdxgen --version

# ---- Trivy 0.70.0 (Apache-2.0). --------------------------------------------
# Container & filesystem vulnerability scanner. Installed from the upstream
# deb (aquasecurity GitHub releases) for a deterministic, signed binary.
# Trivy publishes per-arch debs (Linux-64bit / Linux-ARM64) so we resolve
# the dpkg arch at build time — keeps the image buildable on amd64 CI and
# arm64 dev laptops alike.
ENV TRIVY_VERSION=0.70.0
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
        amd64)  trivy_arch="Linux-64bit" ;; \
        arm64)  trivy_arch="Linux-ARM64" ;; \
        *) echo "Unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL -o /tmp/trivy.deb \
        "https://github.com/aquasecurity/trivy/releases/download/v${TRIVY_VERSION}/trivy_${TRIVY_VERSION}_${trivy_arch}.deb"; \
    dpkg -i /tmp/trivy.deb; \
    rm -f /tmp/trivy.deb; \
    trivy --version

# ---------------------------------------------------------------------------
# Multi-language lockfile resolvers (chore PR #4 — see
# docs/sessions/2026-05-07-uat-multi-ecosystem-matrix.md).
#
# cdxgen needs a populated lockfile to enumerate transitive dependencies;
# without one it returns only direct deps (or zero, e.g. Ruby / Rust / Go).
# These layers ship the per-ecosystem resolvers so the scan_source pipeline
# can call `bundle lock` / `cargo generate-lockfile` / `go mod tidy` /
# `dotnet restore` BEFORE handing the source dir to cdxgen — see
# tasks.scan_source._prepare_for_cdxgen.
#
# Layer order is "smaller / debian-packaged first → manual downloads later"
# so a bump to one of the manual installs (Gradle, Go, .NET) does not bust
# the smaller debian layers.
# ---------------------------------------------------------------------------

# ---- Maven 3.9.x (Apache-2.0). ---------------------------------------------
# Debian bookworm ships maven 3.8.7-1; close enough for SBOM enumeration.
# `--no-install-recommends` avoids pulling default-jdk on top of Temurin 21.
RUN apt-get update \
    && apt-get install -y --no-install-recommends maven \
    && rm -rf /var/lib/apt/lists/* \
    && mvn --version

# ---- Composer 2.x (MIT) + PHP CLI. -----------------------------------------
# Composer needs `php` and either `php-curl` or libcurl on PATH; the
# php-cli + composer combo on Debian bookworm gives us PHP 8.2 + composer
# 2.5, which is plenty for `composer install` lockfile resolution.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        php-cli \
        php-curl \
        php-mbstring \
        php-xml \
        php-zip \
        composer \
    && rm -rf /var/lib/apt/lists/* \
    && composer --version --no-ansi

# ---- Ruby (Ruby License/BSD) + Bundler (MIT). ------------------------------
# Debian bookworm ruby is 3.1.2 + bundler 2.4.x — enough for `bundle lock`.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ruby \
        ruby-bundler \
    && rm -rf /var/lib/apt/lists/* \
    && ruby --version \
    && bundle --version

# ---- Cargo / Rust (MIT/Apache-2.0). ----------------------------------------
# Debian bookworm cargo is 0.66 (rust 1.63) — older than upstream stable but
# fine for `cargo generate-lockfile` (the only command we invoke). A bump to
# rustup-managed cargo would more than double this layer; not worth it
# unless we start running clippy / rustc inside the worker.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        cargo \
    && rm -rf /var/lib/apt/lists/* \
    && cargo --version

# ---- Gradle 8.10.2 (Apache-2.0). -------------------------------------------
# Debian's gradle is 4.4.x — too old for any modern Java project. Install
# the upstream zip into /opt/gradle-${GRADLE_VERSION} and symlink the
# launcher onto PATH. SHA-256 pinned as a build-time constant (the same
# pattern Debian's official `openjdk` and `golang` images use) — bumping
# the version requires bumping the hash deliberately, so a CDN compromise
# can't silently swap a backdoored zip in. Get the next hash with:
#   curl https://services.gradle.org/distributions/gradle-${V}-bin.zip.sha256
# Chore P (Phase 8 worker-image refresh): bumped 8.10.2 → 8.14.3 — latest
# 8.x patch as of 2026-05. We deliberately stay on 8.x rather than jump to
# 9.x: Gradle 9 dropped Java 8/11/16 source compat and reworked the
# configuration cache, which would force every downstream consumer's
# `gradle dependencies` invocation through a compatibility check that
# can fail on older lockfiles. cdxgen calls `gradle dependencies` only as
# an ENUMERATION command, so 8.x covers every modern build (Gradle 8 line
# released through 2026 still receives security patches).
# Hash from https://services.gradle.org/distributions/gradle-8.14.3-bin.zip.sha256
ENV GRADLE_VERSION=8.14.3 \
    GRADLE_SHA256=bd71102213493060956ec229d946beee57158dbd89d0e62b91bca0fa2c5f3531 \
    GRADLE_HOME=/opt/gradle
RUN set -eux; \
    curl -fsSL -o /tmp/gradle.zip \
        "https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip"; \
    echo "${GRADLE_SHA256}  /tmp/gradle.zip" | sha256sum -c -; \
    unzip -q /tmp/gradle.zip -d /opt; \
    mv "/opt/gradle-${GRADLE_VERSION}" "${GRADLE_HOME}"; \
    rm -f /tmp/gradle.zip; \
    ln -s "${GRADLE_HOME}/bin/gradle" /usr/local/bin/gradle; \
    gradle --version

# ---- Go 1.22.7 (BSD-3-Clause). ---------------------------------------------
# Debian bookworm Go is 1.19 — go.mod files since Go 1.21 declare
# `toolchain go1.22.x` and refuse to build on older runtimes. Install the
# upstream tarball with arch detection (linux-amd64 / linux-arm64). Hashes
# pinned per-arch — go.dev/dl/<file>.sha256 redirects to an HTML page (it's
# the human-facing download UI), so we can't fetch the hash that way; the
# raw `.sha256` file lives on dl.google.com but pinning at build time is
# strictly stronger anyway. Get the next pair with:
#   curl https://dl.google.com/go/go${V}.linux-amd64.tar.gz.sha256
#   curl https://dl.google.com/go/go${V}.linux-arm64.tar.gz.sha256
# Chore P (Phase 8 worker-image refresh): bumped 1.22.7 → 1.25.10. The
# previous 1.22.7 bundled `pkg/tool/{trace,vet}` binaries that Trivy
# flagged as carrying CVE-2025-68121 (CRITICAL — crypto/tls session-
# resumption certificate-validation flaw). The fix landed in 1.24.13 /
# 1.25.7 / 1.26.0-rc.3; we go to 1.25.10 (latest 1.25.x) for the longest
# remaining support window without taking 1.26 (released ~2 months ago,
# limited soak time for the toolchain). cdxgen invokes `go list -m all`
# / `go mod` only — both work unchanged across 1.22 → 1.25, and any
# project go.mod with `toolchain go1.22.x` resolves automatically.
# Hashes from https://go.dev/dl/?mode=json (the `files` array of go1.25.10).
ENV GO_VERSION=1.25.10 \
    GO_SHA256_AMD64=42d4f7a32316aa66591eca7e89867256057a4264451aca10570a715b3637ba70 \
    GO_SHA256_ARM64=654da1f9b50a5d1c2a85ccf8ed405aa89c06e94d18384628bf186f7712677b08 \
    GOROOT=/opt/go
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
        amd64) go_arch="linux-amd64"; expected_sha="${GO_SHA256_AMD64}" ;; \
        arm64) go_arch="linux-arm64"; expected_sha="${GO_SHA256_ARM64}" ;; \
        *) echo "Unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    fname="go${GO_VERSION}.${go_arch}.tar.gz"; \
    curl -fsSL -o /tmp/go.tgz "https://dl.google.com/go/${fname}"; \
    echo "${expected_sha}  /tmp/go.tgz" | sha256sum -c -; \
    tar -C /opt -xzf /tmp/go.tgz; \
    rm -f /tmp/go.tgz; \
    ln -s "${GOROOT}/bin/go" /usr/local/bin/go; \
    ln -s "${GOROOT}/bin/gofmt" /usr/local/bin/gofmt; \
    go version

# ---- .NET SDK 8.0 (MIT). ---------------------------------------------------
# cdxgen needs the `dotnet restore` CLI to populate obj/project.assets.json
# for transitive NuGet deps (~700MB layer). Microsoft's Debian apt repo only
# carries dotnet-sdk-8.0 for amd64 — on arm64 (Apple Silicon dev laptops /
# Colima) the package is absent and `apt-get install` fails (E: Unable to
# locate package dotnet-sdk-8.0). The official dotnet-install.sh resolves the
# host arch (x64 / arm64) itself, so the same Dockerfile builds on amd64 CI
# and arm64 dev hosts alike. This is the same cross-arch lesson as Trivy / Go /
# scancode above: pick an install path that resolves on BOTH architectures.
ENV DOTNET_ROOT=/usr/share/dotnet \
    DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_NOLOGO=1
RUN curl -fsSL -o /tmp/dotnet-install.sh "https://dot.net/v1/dotnet-install.sh" \
    && chmod +x /tmp/dotnet-install.sh \
    && /tmp/dotnet-install.sh --channel 8.0 --install-dir "${DOTNET_ROOT}" \
    && rm -f /tmp/dotnet-install.sh \
    && ln -sfn "${DOTNET_ROOT}/dotnet" /usr/local/bin/dotnet \
    && dotnet --version

# ---- scancode-toolkit 32.4.0 (Apache-2.0). ---------------------------------
# First-party license DETECTION (PR-A2 — replaced the broken ORT evaluator).
#
# Cross-arch validated on linux/arm64 (Apple Silicon / Colima) AND amd64. Two
# arm64-specific gotchas were hit during PR-A2 bring-up and are handled here:
#
#   1. PyICU (a scancode transitive dep) ships NO aarch64 wheel and compiles
#      from sdist — needs libicu-dev + pkg-config (installed in the OS-deps
#      RUN above). build-essential comes from stage 1.
#   2. scancode's bundled ``extractcode-libarchive`` / ``typecode-libmagic``
#      wheels are EMPTY STUBS on aarch64 (2 KB), so scancode falls back to a
#      system libarchive/libmagic. Without a complete one it crashes at import
#      with ``undefined symbol: archive_read_new``. We install the full
#      ``libarchive13`` + ``libmagic1`` (OS-deps RUN) and pin scancode's
#      ctypes loader at them via ``EXTRACTCODE_LIBARCHIVE_PATH`` /
#      ``TYPECODE_LIBMAGIC_PATH`` (resolved to the Debian multiarch triplet at
#      build time so the same Dockerfile works on x86_64 and aarch64).
#
# Isolation: scancode pulls a large, version-pinned dependency tree (click /
# lxml / requests / a license index) that would otherwise fight the backend's
# pinned deps (requirements.txt). We install it into a dedicated virtualenv
# under /opt/scancode-venv and symlink only the ``scancode`` launcher onto
# $PATH. The Celery worker process keeps using the system Python from stage 1;
# it shells to ``scancode`` via subprocess (integrations/scancode.py), never
# imports it.
#
# ``scancode-reindex-licenses`` builds scancode's license index at image-build
# time so the first scan does not pay the (multi-minute) index build at
# runtime. It is wrapped in ``|| true`` because a non-fatal index warning must
# not fail the build — the index also self-builds lazily on first scan.
ENV SCANCODE_VERSION=32.4.0 \
    SCANCODE_VENV=/opt/scancode-venv
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
        amd64) triplet="x86_64-linux-gnu" ;; \
        arm64) triplet="aarch64-linux-gnu" ;; \
        *) echo "Unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    python3 -m venv "${SCANCODE_VENV}"; \
    "${SCANCODE_VENV}/bin/pip" install --no-cache-dir --upgrade pip; \
    "${SCANCODE_VENV}/bin/pip" install --no-cache-dir \
        "scancode-toolkit==${SCANCODE_VERSION}"; \
    ln -s "${SCANCODE_VENV}/bin/scancode" /usr/local/bin/scancode; \
    ln -sfn "/usr/lib/${triplet}/libarchive.so.13" /usr/local/lib/scancode-libarchive.so; \
    ln -sfn "/usr/lib/${triplet}/libmagic.so.1" /usr/local/lib/scancode-libmagic.so; \
    EXTRACTCODE_LIBARCHIVE_PATH=/usr/local/lib/scancode-libarchive.so \
    TYPECODE_LIBMAGIC_PATH=/usr/local/lib/scancode-libmagic.so \
        "${SCANCODE_VENV}/bin/scancode-reindex-licenses" || true; \
    EXTRACTCODE_LIBARCHIVE_PATH=/usr/local/lib/scancode-libarchive.so \
    TYPECODE_LIBMAGIC_PATH=/usr/local/lib/scancode-libmagic.so \
        scancode --version

# scancode's ctypes loader reads these at runtime to find a COMPLETE system
# libarchive/libmagic (the bundled aarch64 wheels are empty stubs). The
# arch-stable symlinks above let us pin a fixed path here regardless of the
# Debian multiarch triplet.
ENV EXTRACTCODE_LIBARCHIVE_PATH=/usr/local/lib/scancode-libarchive.so \
    TYPECODE_LIBMAGIC_PATH=/usr/local/lib/scancode-libmagic.so

# Application source. The dev compose bind-mounts ./apps/backend:/app on top
# of this so the COPY here only matters for one-off `docker run` and prod.
COPY . /app

EXPOSE 8000

# Default to celery worker. docker-compose.dev.yml overrides `command:` so the
# concurrency / loglevel can change without rebuilding.
CMD ["celery", "-A", "tasks.celery_app", "worker", "--loglevel=info", "--concurrency=2"]
